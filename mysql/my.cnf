[mysqld]
# Basic settings
user            = mysql
pid-file        = /var/run/mysqld/mysqld.pid
socket          = /var/run/mysqld/mysqld.sock
port            = 3306
datadir         = /var/lib/mysql

# Optimized Performance Settings
# Set to ~75% of available RAM for dedicated DB server, 
# for containerized environments, start at 256M-1G depending on host RAM.
innodb_buffer_pool_size         = 512M
# innodb_log_file_size is deprecated in 8.4, use redo log capacity instead
innodb_redo_log_capacity        = 256M
innodb_log_buffer_size          = 16M
innodb_flush_log_at_trx_commit  = 2
innodb_file_per_table           = 1
innodb_stats_on_metadata        = 0

# Connection settings
max_connections                 = 150
max_allowed_packet              = 64M
thread_cache_size               = 16

# Logging & Binary Log
# sync_binlog = 0 for maximum speed, though it compromises some safety
sync_binlog                     = 0
log_bin_trust_function_creators = 1
slow_query_log                  = 1
slow_query_log_file             = /var/lib/mysql/mysql-slow.log
long_query_time                 = 2

# Character Sets
character-set-server            = utf8mb4
collation-server                 = utf8mb4_unicode_ci

# Disable Performance Schema if memory is tight
# performance_schema             = OFF

[client]
default-character-set           = utf8mb4
